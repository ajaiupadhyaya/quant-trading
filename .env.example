# Copy to .env and fill in your real values. .env is gitignored.

# Alpaca paper trading (https://alpaca.markets)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# FRED (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=...

# Optional
LOG_LEVEL=INFO
QUANT_DATA_DIR=./data

# Off-box alerting (E1 deploy)
HEALTHCHECKS_TICK_URL=
HEALTHCHECKS_GUARD_URL=
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Analyst digest + Slack notifications (E2)
SLACK_WEBHOOK_URL=
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8   # optional override
