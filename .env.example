# Copy to .env and fill in your real values. .env is gitignored.

# Alpaca paper trading (https://alpaca.markets)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# FRED (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=...

# Optional
LOG_LEVEL=INFO
QUANT_DATA_DIR=./data
